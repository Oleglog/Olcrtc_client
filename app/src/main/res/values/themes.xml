    <style name="Widget.OlcrtcClient.SettingsRow" parent="Widget.Material3.Button.TextButton">
        <item name="android:gravity">start|center_vertical</item>
        <item name="android:maxLines">3</item>
        <item name="android:minHeight">68dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:textAlignment">viewStart</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="cornerRadius">0dp</item>
        <item name="iconGravity">end</item>
        <item name="iconTint">?attr/colorOnSurfaceVariant</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.OlcrtcClient.SettingsDivider" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:layout_marginEnd">16dp</item>
        <item name="android:alpha">0.25</item>
        <item name="android:background">?attr/colorOutline</item>

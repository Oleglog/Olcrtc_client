<resources>
    <style name="Theme.OlcrtcClient" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="colorPrimary">@color/olcrtc_primary</item>
        <item name="colorOnPrimary">@color/olcrtc_on_primary</item>
        <item name="colorPrimaryContainer">@color/olcrtc_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/olcrtc_on_primary_container</item>
        <item name="colorSecondary">@color/olcrtc_secondary</item>
        <item name="colorOnSecondary">@color/olcrtc_on_secondary</item>
        <item name="colorSurface">@color/olcrtc_surface</item>
        <item name="colorSurfaceContainer">@color/olcrtc_surface_container</item>
        <item name="colorSurfaceContainerHigh">@color/olcrtc_surface_container_high</item>
        <item name="colorOnSurface">@color/olcrtc_on_surface</item>
        <item name="colorSurfaceVariant">@color/olcrtc_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/olcrtc_on_surface_variant</item>
        <item name="colorOutline">@color/olcrtc_outline</item>
        <item name="colorError">@color/olcrtc_error</item>
        <item name="colorOnError">@color/olcrtc_on_error</item>
        <item name="android:colorBackground">@color/olcrtc_surface</item>
        <item name="android:navigationBarColor">@color/olcrtc_surface</item>
        <item name="android:windowActionModeOverlay">true</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.Olcrtc.Headline</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.Olcrtc.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.Olcrtc.TitleMedium</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.Olcrtc.TitleSmall</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.OlcrtcClient.MediumComponent</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.OlcrtcClient.LargeComponent</item>
    </style>

    <style name="Theme.OlcrtcClient.ProfileChooser" parent="Theme.OlcrtcClient">
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
    </style>

    <style name="ThemeOverlay.OlcrtcClient.Bronze" parent="">
        <item name="colorPrimary">@color/olcrtc_bronze_primary</item>
        <item name="colorOnPrimary">@color/olcrtc_bronze_on_primary</item>
        <item name="colorPrimaryContainer">@color/olcrtc_bronze_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/olcrtc_bronze_on_primary_container</item>
        <item name="colorSecondary">@color/olcrtc_bronze_secondary</item>
        <item name="colorOnSecondary">@color/olcrtc_bronze_on_secondary</item>
        <item name="colorSurface">@color/olcrtc_bronze_surface</item>
        <item name="colorSurfaceContainer">@color/olcrtc_bronze_surface_container</item>
        <item name="colorSurfaceContainerHigh">@color/olcrtc_bronze_surface_container_high</item>
        <item name="colorOnSurface">@color/olcrtc_bronze_on_surface</item>
        <item name="colorSurfaceVariant">@color/olcrtc_bronze_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/olcrtc_bronze_on_surface_variant</item>
        <item name="colorOutline">@color/olcrtc_bronze_outline</item>
        <item name="android:colorBackground">@color/olcrtc_bronze_surface</item>
        <item name="android:navigationBarColor">@color/olcrtc_bronze_surface</item>
    </style>

    <style name="ThemeOverlay.OlcrtcClient.Polar" parent="">
        <item name="colorPrimary">@color/olcrtc_polar_primary</item>
        <item name="colorOnPrimary">@color/olcrtc_polar_on_primary</item>
        <item name="colorPrimaryContainer">@color/olcrtc_polar_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/olcrtc_polar_on_primary_container</item>
        <item name="colorSecondary">@color/olcrtc_polar_secondary</item>
        <item name="colorOnSecondary">@color/olcrtc_polar_on_secondary</item>
        <item name="colorSurface">@color/olcrtc_polar_surface</item>
        <item name="colorSurfaceContainer">@color/olcrtc_polar_surface_container</item>
        <item name="colorSurfaceContainerHigh">@color/olcrtc_polar_surface_container_high</item>
        <item name="colorOnSurface">@color/olcrtc_polar_on_surface</item>
        <item name="colorSurfaceVariant">@color/olcrtc_polar_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/olcrtc_polar_on_surface_variant</item>
        <item name="colorOutline">@color/olcrtc_polar_outline</item>
        <item name="android:colorBackground">@color/olcrtc_polar_surface</item>
        <item name="android:navigationBarColor">@color/olcrtc_polar_surface</item>
    </style>

    <style name="ShapeAppearance.OlcrtcClient.MediumComponent" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">8dp</item>
    </style>

    <style name="Widget.OlcrtcClient.SettingsRow" parent="Widget.Material3.Button.TextButton">
        <item name="android:gravity">start|center_vertical</item>
        <item name="android:maxLines">3</item>
        <item name="android:minHeight">68dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:textAlignment">viewStart</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="cornerRadius">0dp</item>
        <item name="iconGravity">end</item>
        <item name="iconTint">?attr/colorOnSurfaceVariant</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.OlcrtcClient.SettingsDivider" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:layout_marginEnd">16dp</item>
        <item name="android:alpha">0.25</item>
        <item name="android:background">?attr/colorOutline</item>
    </style>

    <style name="Widget.OlcrtcClient.BottomNavigation.ActiveIndicator"
        parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">?attr/colorPrimaryContainer</item>
    </style>

    <style name="ShapeAppearance.OlcrtcClient.LargeComponent" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerSize">8dp</item>
    </style>

    <style name="TextAppearance.Olcrtc.Wordmark" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.04</item>
    </style>

    <style name="TextAppearance.Olcrtc.Headline" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.Olcrtc.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.015</item>
    </style>

    <style name="TextAppearance.Olcrtc.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextAppearance.Olcrtc.TitleSmall" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Olcrtc.Data" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>

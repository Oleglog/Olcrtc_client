<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/page_padding"
        android:paddingTop="@dimen/space_4"
        android:paddingEnd="@dimen/page_padding"
        android:paddingBottom="@dimen/space_3">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/close"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="@dimen/icon_touch_target"
            android:layout_height="@dimen/icon_touch_target"
            android:contentDescription="@string/appearance_navigate_back"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:padding="0dp"
            android:text="@string/appearance_back_symbol"
            android:textColor="?attr/colorOnSurface"
            android:textSize="24sp"
            app:backgroundTint="?attr/colorSurfaceContainerHigh"
            app:cornerRadius="14dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_appearance_title"
                android:textAppearance="?attr/textAppearanceTitleLarge" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/appearance_header_subtitle"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="?attr/colorOnSurfaceVariant" />
        </LinearLayout>

        <Space
            android:layout_width="@dimen/icon_touch_target"
            android:layout_height="@dimen/icon_touch_target"
            android:importantForAccessibility="no" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="@dimen/page_padding"
        android:paddingEnd="@dimen/page_padding"
        android:paddingBottom="@dimen/space_6">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/preview_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/colorSurfaceContainer"
                app:cardCornerRadius="@dimen/corner_card"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/space_4">

                    <FrameLayout
                        android:layout_width="94dp"
                        android:layout_height="94dp">

                        <View
                            android:id="@+id/preview_glow"
                            android:layout_width="94dp"
                            android:layout_height="94dp"
                            android:background="@drawable/bg_connection_halo"
                            android:importantForAccessibility="no" />

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/preview_connect"
                            android:layout_width="86dp"
                            android:layout_height="86dp"
                            android:layout_gravity="center"
                            app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                            app:cardCornerRadius="43dp"
                            app:cardElevation="0dp"
                            app:strokeColor="?attr/colorOutline"
                            app:strokeWidth="1dp">

                            <ImageView
                                android:id="@+id/preview_icon"
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_shield_24" />
                        </com.google.android.material.card.MaterialCardView>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_4"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/preview_label"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.08"
                            android:text="@string/appearance_preview"
                            android:textAllCaps="true"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <TextView
                            android:id="@+id/preview_profile"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_1"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/appearance_preview_profile"
                            android:textAppearance="?attr/textAppearanceTitleMedium" />

                        <TextView
                            android:id="@+id/preview_status"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_1"
                            android:text="@string/appearance_preview_connected"
                            android:textAppearance="?attr/textAppearanceBodySmall" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_3"
                app:cardBackgroundColor="?attr/colorSurfaceContainer"
                app:cardCornerRadius="@dimen/corner_card"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_4">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/appearance_palette_title"
                        android:textAppearance="?attr/textAppearanceTitleMedium" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_1"
                        android:text="@string/appearance_palette_summary"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_3"
                        android:clipToPadding="false"
                        android:overScrollMode="ifContentScrolls"
                        android:scrollbars="none">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:baselineAligned="false"
                            android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/palette_system"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="96dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:checkable="true"
                            android:gravity="center"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:maxLines="2"
                            android:minHeight="72dp"
                            android:minWidth="0dp"
                            android:paddingStart="2dp"
                            android:paddingEnd="2dp"
                            android:text="@string/appearance_palette_system"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="11sp"
                            app:backgroundTint="@color/appearance_palette_background"
                            app:cornerRadius="14dp"
                            app:icon="@drawable/swatch_palette_system"
                            app:iconGravity="textTop"
                            app:iconPadding="6dp"
                            app:iconSize="28dp"
                            app:iconTint="@null"
                            app:strokeColor="@color/appearance_palette_stroke"
                            app:strokeWidth="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/palette_neutral"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="96dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:checkable="true"
                            android:gravity="center"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:maxLines="2"
                            android:minHeight="72dp"
                            android:minWidth="0dp"
                            android:paddingStart="2dp"
                            android:paddingEnd="2dp"
                            android:text="@string/appearance_palette_neutral"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="11sp"
                            app:backgroundTint="@color/appearance_palette_background"
                            app:cornerRadius="14dp"
                            app:icon="@drawable/swatch_palette_neutral"
                            app:iconGravity="textTop"
                            app:iconPadding="6dp"
                            app:iconSize="28dp"
                            app:iconTint="@null"
                            app:strokeColor="@color/appearance_palette_stroke"
                            app:strokeWidth="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/palette_bronze"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="96dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:checkable="true"
                            android:gravity="center"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:maxLines="2"
                            android:minHeight="72dp"
                            android:minWidth="0dp"
                            android:paddingStart="2dp"
                            android:paddingEnd="2dp"
                            android:text="@string/appearance_palette_bronze"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="11sp"
                            app:backgroundTint="@color/appearance_palette_background"
                            app:cornerRadius="14dp"
                            app:icon="@drawable/swatch_palette_bronze"
                            app:iconGravity="textTop"
                            app:iconPadding="6dp"
                            app:iconSize="28dp"
                            app:iconTint="@null"
                            app:strokeColor="@color/appearance_palette_stroke"
                            app:strokeWidth="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/palette_black"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="96dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:checkable="true"
                            android:gravity="center"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:maxLines="2"
                            android:minHeight="72dp"
                            android:minWidth="0dp"
                            android:paddingStart="2dp"
                            android:paddingEnd="2dp"
                            android:text="@string/appearance_palette_black"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="11sp"
                            app:backgroundTint="@color/appearance_palette_background"
                            app:cornerRadius="14dp"
                            app:icon="@drawable/swatch_palette_black"
                            app:iconGravity="textTop"
                            app:iconPadding="6dp"
                            app:iconSize="28dp"
                            app:iconTint="@null"
                            app:strokeColor="@color/appearance_palette_stroke"
                            app:strokeWidth="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/palette_mono"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="96dp"
                            android:layout_height="wrap_content"
                            android:checkable="true"
                            android:gravity="center"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:maxLines="2"
                            android:minHeight="72dp"
                            android:minWidth="0dp"
                            android:paddingStart="2dp"
                            android:paddingEnd="2dp"
                            android:text="@string/appearance_palette_mono"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="11sp"
                            app:backgroundTint="@color/appearance_palette_background"
                            app:cornerRadius="14dp"
                            app:icon="@drawable/swatch_palette_mono"
                            app:iconGravity="textTop"
                            app:iconPadding="6dp"
                            app:iconSize="28dp"
                            app:iconTint="@null"
                            app:strokeColor="@color/appearance_palette_stroke"
                            app:strokeWidth="1dp" />
                        </LinearLayout>
                    </HorizontalScrollView>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_4"
                        android:text="@string/appearance_accent_title"
                        android:textAppearance="?attr/textAppearanceLabelLarge" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_1"
                        android:text="@string/appearance_accent_summary"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_3"
                        android:clipToPadding="false"
                        android:overScrollMode="ifContentScrolls"
                        android:scrollbars="none">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/accent_auto"
                                style="?attr/materialButtonOutlinedStyle"
                                android:layout_width="96dp"
                                android:layout_height="48dp"
                                android:layout_marginEnd="@dimen/space_2"
                                android:checkable="true"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:minWidth="0dp"
                                android:text="@string/appearance_accent_auto"
                                app:backgroundTint="?attr/colorSurfaceContainerHigh"
                                app:cornerRadius="16dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/accent_teal"
                                style="?attr/materialButtonOutlinedStyle"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:layout_marginEnd="@dimen/space_2"
                                android:checkable="true"
                                android:contentDescription="@string/appearance_accent_teal"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:minWidth="0dp"
                                android:text=""
                                app:backgroundTint="@color/appearance_accent_teal"
                                app:cornerRadius="16dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/accent_blue"
                                style="?attr/materialButtonOutlinedStyle"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:layout_marginEnd="@dimen/space_2"
                                android:checkable="true"
                                android:contentDescription="@string/appearance_accent_blue"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:minWidth="0dp"
                                android:text=""
                                app:backgroundTint="@color/appearance_accent_blue"
                                app:cornerRadius="16dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/accent_violet"
                                style="?attr/materialButtonOutlinedStyle"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:layout_marginEnd="@dimen/space_2"
                                android:checkable="true"
                                android:contentDescription="@string/appearance_accent_violet"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:minWidth="0dp"
                                android:text=""
                                app:backgroundTint="@color/appearance_accent_violet"
                                app:cornerRadius="16dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/accent_rose"
                                style="?attr/materialButtonOutlinedStyle"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:layout_marginEnd="@dimen/space_2"
                                android:checkable="true"
                                android:contentDescription="@string/appearance_accent_rose"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:minWidth="0dp"
                                android:text=""
                                app:backgroundTint="@color/appearance_accent_rose"
                                app:cornerRadius="16dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/accent_amber"
                                style="?attr/materialButtonOutlinedStyle"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:checkable="true"
                                android:contentDescription="@string/appearance_accent_amber"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:minWidth="0dp"
                                android:text=""
                                app:backgroundTint="@color/appearance_accent_amber"
                                app:cornerRadius="16dp" />
                        </LinearLayout>
                    </HorizontalScrollView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_3"
                app:cardBackgroundColor="?attr/colorSurfaceContainer"
                app:cardCornerRadius="@dimen/corner_card"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_4">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/appearance_atmosphere_title"
                        android:textAppearance="?attr/textAppearanceTitleMedium" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_1"
                        android:text="@string/appearance_atmosphere_summary"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/effect_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_2"
                        app:selectionRequired="true"
                        app:singleSelection="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/effect_snow"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/settings_background_effect_snow" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/effect_rain"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/settings_background_effect_rain" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/effect_drift"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/settings_background_effect_drift" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>

                    <TextView
                        android:id="@+id/drift_intensity_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_3"
                        android:text="@string/settings_background_effect_intensity"
                        android:textAppearance="?attr/textAppearanceLabelLarge" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/intensity_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_2"
                        app:selectionRequired="true"
                        app:singleSelection="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/intensity_low"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/settings_background_effect_intensity_low" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/intensity_medium"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/settings_background_effect_intensity_medium" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/intensity_high"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/settings_background_effect_intensity_high" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_4"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/appearance_glow_intensity"
                            android:textAppearance="?attr/textAppearanceLabelLarge" />

                        <TextView
                            android:id="@+id/glow_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:textAppearance="?attr/textAppearanceLabelLarge"
                            android:textColor="?attr/colorPrimary" />
                    </LinearLayout>

                    <com.google.android.material.slider.Slider
                        android:id="@+id/glow_slider"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:contentDescription="@string/appearance_glow_intensity" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_3"
                app:cardBackgroundColor="?attr/colorSurfaceContainer"
                app:cardCornerRadius="@dimen/corner_card"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/space_4"
                    android:paddingTop="@dimen/space_3"
                    android:paddingEnd="@dimen/space_3"
                    android:paddingBottom="@dimen/space_3">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/appearance_motion_title"
                            android:textAppearance="?attr/textAppearanceTitleSmall" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/appearance_motion_summary"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/motion_enabled"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_3"
                        android:contentDescription="@string/appearance_motion_title" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/apply"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/page_padding"
        android:layout_marginEnd="@dimen/page_padding"
        android:layout_marginBottom="@dimen/space_4"
        android:minHeight="@dimen/button_primary_height"
        android:text="@string/appearance_apply"
        app:cornerRadius="@dimen/corner_button" />
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/main_pager"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <io.github.oleglog.olcrtc.client.ui.ParticleDriftView
            android:id="@+id/background_effects"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="false"
            android:focusable="false"
            android:importantForAccessibility="no"
            android:visibility="gone" />
    </FrameLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="12dp"
        app:cardBackgroundColor="?attr/colorSurfaceContainer"
        app:cardCornerRadius="24dp"
        app:cardElevation="6dp"
        app:strokeColor="?attr/colorOutline"
        app:strokeWidth="1dp">

        <LinearLayout
            android:id="@+id/bottom_navigation"
            android:layout_width="match_parent"
            android:layout_height="92dp"
            android:background="@android:color/transparent"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <LinearLayout
                android:id="@+id/navigation_connection"
                style="@style/Widget.OlcrtcClient.BottomNavigation.Item"
                android:contentDescription="@string/navigation_connection">

                <FrameLayout
                    style="@style/Widget.OlcrtcClient.BottomNavigation.Indicator">

                    <ImageView
                        style="@style/Widget.OlcrtcClient.BottomNavigation.Icon"
                        android:src="@drawable/ic_nav_connection_24" />
                </FrameLayout>

                <TextView
                    style="@style/Widget.OlcrtcClient.BottomNavigation.Label"
                    android:text="@string/navigation_connection" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navigation_profiles"
                style="@style/Widget.OlcrtcClient.BottomNavigation.Item"
                android:contentDescription="@string/navigation_profiles">

                <FrameLayout
                    style="@style/Widget.OlcrtcClient.BottomNavigation.Indicator">

                    <ImageView
                        style="@style/Widget.OlcrtcClient.BottomNavigation.Icon"
                        android:src="@drawable/ic_nav_subscriptions_24" />
                </FrameLayout>

                <TextView
                    style="@style/Widget.OlcrtcClient.BottomNavigation.Label"
                    android:text="@string/navigation_profiles" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navigation_statistics"
                style="@style/Widget.OlcrtcClient.BottomNavigation.Item"
                android:contentDescription="@string/navigation_statistics">

                <FrameLayout
                    style="@style/Widget.OlcrtcClient.BottomNavigation.Indicator">

                    <ImageView
                        style="@style/Widget.OlcrtcClient.BottomNavigation.Icon"
                        android:src="@drawable/ic_nav_statistics_24" />
                </FrameLayout>

                <TextView
                    style="@style/Widget.OlcrtcClient.BottomNavigation.Label"
                    android:text="@string/navigation_statistics" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navigation_settings"
                style="@style/Widget.OlcrtcClient.BottomNavigation.Item"
                android:contentDescription="@string/navigation_settings">

                <FrameLayout
                    style="@style/Widget.OlcrtcClient.BottomNavigation.Indicator">

                    <ImageView
                        style="@style/Widget.OlcrtcClient.BottomNavigation.Icon"
                        android:src="@drawable/ic_nav_settings_24" />
                </FrameLayout>

                <TextView
                    style="@style/Widget.OlcrtcClient.BottomNavigation.Label"
                    android:text="@string/navigation_settings" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>

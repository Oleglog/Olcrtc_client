<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/page_padding">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/navigation_settings"
            android:textAppearance="?attr/textAppearanceHeadlineMedium" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/settings_routing_row"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_4"
            android:gravity="start|center_vertical"
            android:maxLines="3"
            android:minHeight="64dp"
            android:text="@string/settings_routing_title"
            app:cornerRadius="@dimen/corner_button"
            app:icon="@drawable/ic_chevron_right_24"
            app:iconGravity="textEnd" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/settings_apps_row"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2"
            android:gravity="start|center_vertical"
            android:maxLines="3"
            android:minHeight="64dp"
            android:text="@string/settings_per_app_title"
            app:cornerRadius="@dimen/corner_button"
            app:icon="@drawable/ic_chevron_right_24"
            app:iconGravity="textEnd" />

        <FrameLayout
            android:id="@+id/settings_effects_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2"
            android:background="@drawable/bg_settings_row"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:minHeight="64dp"
            android:padding="@dimen/space_3">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:orientation="vertical"
                android:paddingEnd="64dp">

                <TextView
                    android:id="@+id/settings_effects_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_background_effects"
                    android:textAppearance="?attr/textAppearanceTitleSmall" />

                <TextView
                    android:id="@+id/settings_effects_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_1"
                    android:text="@string/settings_background_effects_summary"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/settings_effects_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|center_vertical" />
        </FrameLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/settings_dns_row"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2"
            android:gravity="start|center_vertical"
            android:maxLines="3"
            android:minHeight="64dp"
            android:text="@string/dns_server"
            app:cornerRadius="@dimen/corner_button"
            app:icon="@drawable/ic_chevron_right_24"
            app:iconGravity="textEnd" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/settings_system_row"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2"
            android:gravity="start|center_vertical"
            android:maxLines="3"
            android:minHeight="64dp"
            android:text="@string/settings_system_title"
            app:cornerRadius="@dimen/corner_button"
            app:icon="@drawable/ic_chevron_right_24"
            app:iconGravity="textEnd" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/settings_updates_row"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2"
            android:gravity="start|center_vertical"
            android:maxLines="3"
            android:minHeight="64dp"
            android:text="@string/settings_updates_title"
            app:cornerRadius="@dimen/corner_button"
            app:icon="@drawable/ic_chevron_right_24"
            app:iconGravity="textEnd" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/settings_diagnostics_row"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2"
            android:gravity="start|center_vertical"
            android:maxLines="3"
            android:minHeight="64dp"
            android:text="@string/settings_diagnostics_title"
            app:cornerRadius="@dimen/corner_button"
            app:icon="@drawable/ic_chevron_right_24"
            app:iconGravity="textEnd" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/settings_about_row"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2"
            android:gravity="start|center_vertical"
            android:maxLines="3"
            android:minHeight="64dp"
            android:text="@string/settings_about"
            app:cornerRadius="@dimen/corner_button"
            app:icon="@drawable/ic_chevron_right_24"
            app:iconGravity="textEnd" />

        <TextView
            android:id="@+id/status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_4"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

    </LinearLayout>
</ScrollView>

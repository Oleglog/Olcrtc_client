<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/page_padding">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/navigation_settings"
            android:textAppearance="?attr/textAppearanceHeadlineMedium" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/settings_routing_row"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_4"
            android:gravity="start|center_vertical"
            android:maxLines="3"
            android:minHeight="64dp"
            android:text="@string/settings_routing_title"
            app:icon="@drawable/ic_chevron_right_24"
            app:iconGravity="textEnd" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/settings_apps_row"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2"
            android:gravity="start|center_vertical"
            android:maxLines="3"
            android:minHeight="64dp"
            android:text="@string/settings_per_app_title"
            app:icon="@drawable/ic_chevron_right_24"
            app:iconGravity="textEnd" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/settings_dns_row"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2"
            android:gravity="start|center_vertical"
            android:maxLines="3"
            android:minHeight="64dp"
            android:text="@string/dns_server"
            app:icon="@drawable/ic_chevron_right_24"
            app:iconGravity="textEnd" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/settings_system_row"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2"
            android:gravity="start|center_vertical"
            android:maxLines="3"
            android:minHeight="64dp"
            android:text="@string/settings_system_title"
            app:icon="@drawable/ic_chevron_right_24"
            app:iconGravity="textEnd" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/settings_updates_row"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2"
            android:gravity="start|center_vertical"
            android:maxLines="3"
            android:minHeight="64dp"
            android:text="@string/settings_check_update"
            app:icon="@drawable/ic_chevron_right_24"
            app:iconGravity="textEnd" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/settings_diagnostics_row"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2"
            android:gravity="start|center_vertical"
            android:maxLines="3"
            android:minHeight="64dp"
            android:text="@string/settings_diagnostics_title"
            app:icon="@drawable/ic_chevron_right_24"
            app:iconGravity="textEnd" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/settings_about_row"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2"
            android:gravity="start|center_vertical"
            android:maxLines="3"
            android:minHeight="64dp"
            android:text="@string/settings_about"
            app:icon="@drawable/ic_chevron_right_24"
            app:iconGravity="textEnd" />

        <TextView
            android:id="@+id/status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_4"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

    </LinearLayout>
</ScrollView>

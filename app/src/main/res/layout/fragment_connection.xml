<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/connection_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls"
        android:paddingBottom="@dimen/space_5">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:paddingStart="@dimen/page_padding"
            android:paddingEnd="@dimen/page_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="64dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="@dimen/space_4"
                android:paddingBottom="@dimen/space_3">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/brand_olc"
                        android:textAppearance="@style/TextAppearance.Olcrtc.Wordmark" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/brand_rtc"
                        android:textAppearance="@style/TextAppearance.Olcrtc.Wordmark"
                        android:textColor="?attr/colorPrimary" />
                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/content_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="64dp"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="@dimen/space_4">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/content_loading"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:indeterminate="true"
                    app:indicatorSize="32dp"
                    app:trackThickness="3dp" />

                <TextView
                    android:id="@+id/content_state_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4"
                    android:gravity="center"
                    android:text="@string/connection_loading_title"
                    android:textAppearance="?attr/textAppearanceTitleMedium" />

                <TextView
                    android:id="@+id/content_state_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_2"
                    android:gravity="center"
                    android:text="@string/connection_loading_message"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/content_state_action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4"
                    android:minHeight="@dimen/button_secondary_height"
                    android:minWidth="160dp"
                    android:text="@string/add_connection"
                    android:visibility="gone"
                    app:cornerRadius="@dimen/corner_button"
                    app:icon="@drawable/ic_add_24" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/action_area"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/connection_status_dot"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:background="@drawable/bg_connection_status_dot" />

                    <TextView
                        android:id="@+id/connection_summary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_2"
                        android:gravity="center"
                        android:text="@string/vpn_notification_disconnected"
                        android:textAppearance="?attr/textAppearanceLabelLarge"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <FrameLayout
                    android:layout_width="300dp"
                    android:layout_height="300dp"
                    android:layout_marginTop="@dimen/space_1"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <io.github.oleglog.olcrtc.client.ui.ConnectionGlowView
                        android:id="@+id/connection_halo"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center" />

                    <View
                        android:layout_width="218dp"
                        android:layout_height="218dp"
                        android:layout_gravity="center"
                        android:alpha="0.48"
                        android:background="@drawable/bg_connection_ring"
                        android:importantForAccessibility="no" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/connect"
                        android:layout_width="198dp"
                        android:layout_height="198dp"
                        android:layout_gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="?attr/colorSurfaceContainer"
                        app:cardCornerRadius="99dp"
                        app:cardElevation="3dp"
                        app:rippleColor="?attr/colorPrimary"
                        app:strokeColor="?attr/colorOutline"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/space_4">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="52dp"
                                android:layout_height="52dp"
                                app:cardBackgroundColor="?attr/colorPrimary"
                                app:cardCornerRadius="26dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:id="@+id/connect_icon"
                                    android:layout_width="26dp"
                                    android:layout_height="26dp"
                                    android:layout_gravity="center"
                                    android:contentDescription="@null"
                                    android:src="@drawable/ic_power_24"
                                    app:tint="?attr/colorOnPrimary" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:id="@+id/connect_title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_3"
                                android:gravity="center"
                                android:text="@string/connect"
                                android:textAppearance="@style/TextAppearance.Olcrtc.TitleLarge"
                                android:textSize="23sp"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:id="@+id/connection_timer"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_1"
                                android:text="@string/connection_timer_zero"
                                android:textAppearance="@style/TextAppearance.Olcrtc.Data"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </FrameLayout>

                <TextView
                    android:id="@+id/status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_3"
                    android:background="@drawable/bg_status_message"
                    android:padding="@dimen/space_3"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_5"
                    android:text="@string/connection_profiles"
                    android:textAppearance="?attr/textAppearanceTitleMedium" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_2"
                    android:clipToPadding="false"
                    android:fillViewport="true"
                    android:overScrollMode="ifContentScrolls"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/profile_list"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />

                </HorizontalScrollView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_3"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="@dimen/button_secondary_height"
                        android:layout_marginEnd="@dimen/space_2"
                        android:layout_weight="1">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/test_selected"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:fontFamily="monospace"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="0dp"
                            android:text="@string/profile_test_latency"
                            app:cornerRadius="@dimen/corner_button"
                            app:icon="@drawable/ic_ping_24"
                            app:iconGravity="textStart" />

                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/ping_progress"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:indeterminate="true"
                            android:visibility="gone"
                            app:indicatorSize="22dp"
                            app:trackThickness="2dp" />
                    </FrameLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/add_profile"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/button_secondary_height"
                        android:layout_weight="1"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:text="@string/add_connection"
                        app:cornerRadius="@dimen/corner_button"
                        app:icon="@drawable/ic_add_24"
                        app:iconGravity="textStart" />

                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_3"
                    app:cardBackgroundColor="?attr/colorSurfaceContainer"
                    app:cardCornerRadius="@dimen/corner_quiet"
                    app:cardElevation="2dp"
                    app:strokeColor="?attr/colorOutline"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_4">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/connection_today"
                            android:textAppearance="?attr/textAppearanceTitleMedium" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_4"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/today_download"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/traffic_zero_rate"
                                    android:textAppearance="@style/TextAppearance.Olcrtc.Data"
                                    android:textSize="13sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/space_1"
                                    android:text="@string/connection_download"
                                    android:textAppearance="?attr/textAppearanceLabelSmall"
                                    android:textColor="?attr/colorOnSurfaceVariant" />
                            </LinearLayout>

                            <View
                                android:layout_width="1dp"
                                android:layout_height="match_parent"
                                android:layout_marginEnd="@dimen/space_3"
                                android:alpha="0.35"
                                android:background="?attr/colorOutline"
                                android:importantForAccessibility="no" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/today_upload"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/traffic_zero_rate"
                                    android:textAppearance="@style/TextAppearance.Olcrtc.Data"
                                    android:textSize="13sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/space_1"
                                    android:text="@string/connection_upload"
                                    android:textAppearance="?attr/textAppearanceLabelSmall"
                                    android:textColor="?attr/colorOnSurfaceVariant" />
                            </LinearLayout>

                            <View
                                android:layout_width="1dp"
                                android:layout_height="match_parent"
                                android:layout_marginEnd="@dimen/space_3"
                                android:alpha="0.35"
                                android:background="?attr/colorOutline"
                                android:importantForAccessibility="no" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/today_total"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/traffic_zero"
                                    android:textAppearance="@style/TextAppearance.Olcrtc.Data"
                                    android:textSize="13sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/space_1"
                                    android:text="@string/connection_total_today"
                                    android:textAppearance="?attr/textAppearanceLabelSmall"
                                    android:textColor="?attr/colorOnSurfaceVariant" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>

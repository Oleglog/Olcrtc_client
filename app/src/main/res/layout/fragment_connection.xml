<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/page_padding"
        android:paddingTop="@dimen/space_5"
        android:paddingEnd="@dimen/page_padding"
        android:paddingBottom="@dimen/space_2">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/navigation_connection"
            android:textAppearance="?attr/textAppearanceTitleLarge" />

        <TextView
            android:id="@+id/connection_summary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_3"
            android:gravity="end"
            android:maxLines="2"
            android:text="@string/vpn_notification_disconnected"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?attr/colorOnSurfaceVariant" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/connection_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/page_padding"
            android:paddingEnd="@dimen/page_padding"
            android:paddingBottom="@dimen/space_3">

            <LinearLayout
                android:id="@+id/content_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="@dimen/space_4">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/content_loading"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:indeterminate="true"
                    app:indicatorSize="32dp"
                    app:trackThickness="3dp" />

                <TextView
                    android:id="@+id/content_state_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4"
                    android:gravity="center"
                    android:text="@string/connection_loading_title"
                    android:textAppearance="?attr/textAppearanceTitleMedium" />

                <TextView
                    android:id="@+id/content_state_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_2"
                    android:gravity="center"
                    android:text="@string/connection_loading_message"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/content_state_action"
                    style="?attr/materialButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4"
                    android:minHeight="@dimen/button_secondary_height"
                    android:minWidth="160dp"
                    android:text="@string/add_connection"
                    android:visibility="gone"
                    app:cornerRadius="@dimen/corner_button"
                    app:icon="@drawable/ic_add_24" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/profile_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <TextView
        android:id="@+id/status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/page_padding"
        android:layout_marginTop="@dimen/space_2"
        android:layout_marginEnd="@dimen/page_padding"
        android:background="@drawable/bg_status_message"
        android:padding="@dimen/space_3"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/action_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:elevation="2dp"
        android:orientation="vertical"
        android:paddingStart="@dimen/page_padding"
        android:paddingTop="@dimen/space_3"
        android:paddingEnd="@dimen/page_padding"
        android:paddingBottom="@dimen/space_4"
        android:visibility="gone">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/connect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/button_primary_height"
            android:text="@string/connect"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            app:cornerRadius="@dimen/corner_button" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/add_profile"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:maxLines="2"
                android:minHeight="@dimen/button_secondary_height"
                android:text="@string/add_connection"
                app:cornerRadius="@dimen/corner_button"
                app:icon="@drawable/ic_add_24" />

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_2"
                android:layout_weight="1"
                android:minHeight="@dimen/button_secondary_height">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/test_selected"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/button_secondary_height"
                    android:text="@string/profile_test_latency"
                    app:cornerRadius="@dimen/corner_button"
                    app:icon="@drawable/ic_ping_24" />

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/ping_progress"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:indeterminate="true"
                    android:visibility="gone"
                    app:indicatorSize="24dp"
                    app:trackThickness="2dp" />
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
